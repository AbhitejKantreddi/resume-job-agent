# ---- Groq (fast LLM inference) -------------------------------------------
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional: override the API base URL (defaults to https://api.groq.com/openai/v1)
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---- Tavily (live web search for jobs) -----------------------------------
# Get a key: https://tavily.com
TAVILY_API_KEY=

# ---- Behaviour -----------------------------------------------------------
# Default location used in the job-search query template.
DEFAULT_LOCATION=Remote

# Comma-separated list of allowed frontend origins (CORS).
FRONTEND_ORIGINS=http://localhost:3000

# NOTE: If GROQ_API_KEY is empty, the backend runs in MOCK mode and returns
# realistic sample data so you can demo the full pipeline + UI without any keys.
